<Window x:Class="Pogoda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:Pogoda.Converters"
        mc:Ignorable="d"
        Title="Погода - Прогноз погоды" 
        Height="800" 
        Width="1200"
        Background="#FFF5F5F5">

    <Window.Resources>
        <conv:IconConverter x:Key="IconConverter"/>

        <Style TargetType="TextBlock" x:Key="HeaderText">
            <Setter Property="Foreground" Value="#FF424242"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF212121"/>
            <Setter Property="BorderBrush" Value="#FFBDBDBD"/>
            <Setter Property="CaretBrush" Value="#FF212121"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Image">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
        </Style>

        <!-- Стили кнопок -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF1976D2"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#FF1976D2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" 
                Background="#FFFFFFFF" 
                CornerRadius="8" 
                Padding="10" 
                Margin="0,0,0,10"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Прогноз погоды" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#FF1976D2" 
                           HorizontalAlignment="Center"/>

                <WrapPanel Margin="0,10,0,0" HorizontalAlignment="Center">
                    <TextBox Text="{Binding CityInput, UpdateSourceTrigger=PropertyChanged}" 
                             Width="200" 
                             Margin="5" 
                             Padding="8"
                             materialDesign:HintAssist.Hint="Введите город"/>
                    <Button Content="Узнать погоду" 
                            Command="{Binding GetPogodaCommand}" 
                            Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Добавить город" 
                            Command="{Binding AddCityCommand}" 
                            Style="{StaticResource SecondaryButton}"/>
                </WrapPanel>

                <!-- Список городов -->
                <WrapPanel Margin="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding Cities}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" 
                                        Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.SelectCityCommand}" 
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButton}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Карточка текущей погоды -->
        <Border Grid.Row="1" 
                Background="#FFFFFFFF" 
                CornerRadius="8" 
                Padding="20" 
                Margin="0,0,0,10"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <TextBlock Text="{Binding CityName}" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#FF1976D2"/>
                    <TextBlock Text="{Binding PogodaDescription}" 
                               FontSize="16" 
                               Foreground="#FF616161" 
                               Margin="0,5,0,0"/>
                    <TextBlock Text="Текущая погода" 
                               FontSize="12" 
                               Foreground="#FF9E9E9E" 
                               Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Image Source="{Binding PogodaIcon, Converter={StaticResource IconConverter}}" 
                           Width="80" 
                           Height="80" 
                           Margin="0,0,20,0"/>
                    <TextBlock FontSize="64" 
                               FontWeight="Bold" 
                               Foreground="#FF212121" 
                               HorizontalAlignment="Center"
                               Text="{Binding Temperature, StringFormat={}{0}°C}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Grid.Column="0" 
                                   Text="💧 Влажность:" 
                                   Style="{StaticResource HeaderText}" 
                                   Margin="0,5,10,5"/>
                        <TextBlock Grid.Row="0" 
                                   Grid.Column="1" 
                                   Foreground="#FF424242" 
                                   Margin="0,5,0,5"
                                   Text="{Binding Humidity, StringFormat={}{0}%}"/>

                        <TextBlock Grid.Row="1" 
                                   Grid.Column="0" 
                                   Text="💨 Ветер:" 
                                   Style="{StaticResource HeaderText}" 
                                   Margin="0,5,10,5"/>
                        <TextBlock Grid.Row="1" 
                                   Grid.Column="1" 
                                   Foreground="#FF424242" 
                                   Margin="0,5,0,5"
                                   Text="{Binding WindSpeed, StringFormat={}{0:F1} м/с}"/>

                        <TextBlock Grid.Row="2" 
                                   Grid.Column="0" 
                                   Text="📊 Давление:" 
                                   Style="{StaticResource HeaderText}" 
                                   Margin="0,5,10,5"/>
                        <TextBlock Grid.Row="2" 
                                   Grid.Column="1" 
                                   Foreground="#FF424242" 
                                   Margin="0,5,0,5"
                                   Text="{Binding Pressure, StringFormat={}{0} гПа}"/>

                        <TextBlock Grid.Row="3" 
                                   Grid.Column="0" 
                                   Text="🌡️ Ощущается как:" 
                                   Style="{StaticResource HeaderText}" 
                                   Margin="0,5,10,5"/>
                        <TextBlock Grid.Row="3" 
                                   Grid.Column="1" 
                                   Foreground="#FF424242" 
                                   Margin="0,5,0,5"
                                   Text="{Binding FeelsLike, StringFormat={}{0}°C}"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Прогноз и график -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Карточки прогноза -->
            <Border Grid.Row="0" 
                    Background="#FFFFFFFF" 
                    CornerRadius="8" 
                    Padding="15" 
                    Margin="0,0,0,10"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Прогноз на 3 дня" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#FF1976D2" 
                               Margin="0,0,0,15"/>
                    <ItemsControl ItemsSource="{Binding DailyForecasts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF8F8F8" 
                                        CornerRadius="8" 
                                        Width="190" 
                                        Margin="5" 
                                        Padding="10"
                                        BorderBrush="#FFE0E0E0"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" 
                                                   Foreground="#FF1976D2" 
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:dddd}, {0:MMMM d}">
                                                    <Binding Path="Date"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <TextBlock Text="{Binding Date, StringFormat=dd.MM.yyyy}" 
                                                   FontSize="11" 
                                                   Foreground="#FF757575" 
                                                   HorizontalAlignment="Center" 
                                                   Margin="0,5,0,0"/>
                                        <Image Source="{Binding Icon, Converter={StaticResource IconConverter}}" 
                                               Width="50" 
                                               Height="50" 
                                               Margin="0,10,0,5"/>
                                        <TextBlock Text="{Binding Description}" 
                                                   Foreground="#FF424242" 
                                                   HorizontalAlignment="Center" 
                                                   Margin="0,5,0,0" 
                                                   TextWrapping="Wrap" 
                                                   FontSize="11"/>
                                        <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Center" 
                                                    Margin="0,10,0,0">
                                            <TextBlock Foreground="#FF1565C0" 
                                                       Margin="0,0,10,0"
                                                       Text="{Binding MinTemp, StringFormat={}{0}°}"/>
                                            <TextBlock Foreground="#FFC62828"
                                                       Text="{Binding MaxTemp, StringFormat={}{0}°}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- График температуры -->
            <Border Grid.Row="1" 
                    Background="#FFFFFFFF" 
                    CornerRadius="8" 
                    Padding="15"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Температура (следующие 24 часа)" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#FF1976D2" 
                               Margin="0,0,0,15"/>
                    <lvc:CartesianChart Series="{Binding TemperatureSeries}" 
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        Height="300"
                                        Background="#FFFFFFFF">
                    </lvc:CartesianChart>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Нижняя панель статуса -->
        <Border Grid.Row="3" 
                Background="#FFFFFFFF" 
                CornerRadius="8" 
                Padding="10" 
                Margin="0,10,0,0"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="#FF757575" 
                           FontSize="11"/>
                <TextBlock Text="Автообновление каждые 5 минут" 
                           Foreground="#FF757575" 
                           FontSize="11" 
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>